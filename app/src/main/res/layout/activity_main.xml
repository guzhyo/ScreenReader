<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FAFAFA">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="屏幕内容读取器"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="通过无障碍服务实时获取屏幕内容"
        android:textSize="13sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- 步骤1：无障碍权限 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="步骤 1：开启无障碍服务"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:layout_marginBottom="6dp" />

    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启无障碍服务"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="16dp" />

    <!-- 步骤2：悬浮窗权限 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="步骤 2：开启悬浮窗权限"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:layout_marginBottom="6dp" />

    <Button
        android:id="@+id/btn_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启悬浮窗权限"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="16dp" />

    <!-- 步骤3：最小化 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="步骤 3：最小化应用"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:layout_marginBottom="6dp" />

    <Button
        android:id="@+id/btn_minimize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="最小化（悬浮球工作中）"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9E9E9E"
        android:enabled="false"
        android:layout_marginBottom="24dp" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- 状态 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请先开启无障碍服务"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="在系统设置中找到「屏幕读取器」并启用"
        android:textSize="13sp"
        android:textColor="#666666"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
